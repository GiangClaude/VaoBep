# Backend environment variables for Chatbot integration

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=vaobep_ai_bot
DB_PASSWORD=toilabot
DB_NAME=VaoBep

# Redis (rate-limiting + cache)
# Example: redis://:password@localhost:6379
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379

# Google / Gemini
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Pinecone
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_ENV=us-east-1
PINECONE_INDEX=vaobep-data

# Langfuse
LANGFUSE_SECRET_KEY=YOUR_LANGFUSE_SECRET
LANGFUSE_PUBLIC_KEY=YOUR_LANGFUSE_PUBLIC
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Chatbot limits
CHATBOT_MAX_ROWS=200
CHATBOT_SQL_TIMEOUT_MS=2000
RATE_LIMIT_PER_USER=2
GLOBAL_RPM=15

# Optional
REDIS_CACHE_TTL_SECONDS=600
